# Claude Bridge — environment variables
# Copy this to .env for local testing, or set these in Railway's Variables tab.
# Never commit a .env file with real keys to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret token callers (including the Custom GPT) must send in the
# Authorization: Bearer header. Generate a random string, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BRIDGE_API_KEY=generate-a-random-secret-here

# Your Anthropic API key (from console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# ── Add when ready ────────────────────────────────────────────────────────────

# Your OpenAI API key (from platform.openai.com/api-keys)
# Leave as PLACEHOLDER until you have the key — the bridge starts fine without it.
# Adversarial sessions and ask_openai calls will return a clear error until set.
OPENAI_API_KEY=PLACEHOLDER

# ── Optional ──────────────────────────────────────────────────────────────────

ANTHROPIC_DEFAULT_MODEL=claude-opus-4-6
OPENAI_DEFAULT_MODEL=gpt-4o

# Absolute path to the adversarial-ai/roles directory.
# On Railway, this is relative to the repo root — set it to the correct path
# once you know your Railway project's directory layout.
# ROLES_DIR=/app/adversarial-ai/roles

# Path for the SQLite usage log. Defaults to usage.db next to server.py.
# On Railway, use a volume mount path if you want persistence across deploys.
# BRIDGE_LOG_DB=/data/usage.db
